{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "types": ["vitepress/client"]
  },
  "include": ["**/*.ts", "**/*.vue"],
  "exclude": ["node_modules", ".vitepress/dist", ".vitepress/cache"]
}
